# ============================================================
# COPIE ESTE ARQUIVO PARA .env E PREENCHA OS VALORES REAIS
# NUNCA envie o .env para o GitHub!
# ============================================================

# --- Ambiente ---
APP_ENV="development"  # "development" ou "production"
ALLOWED_ORIGINS="http://localhost:5173"  # Em produção: URL real do Front-end

# --- Segurança JWT (OBRIGATÓRIO) ---
# Gere com: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET_KEY=""
JWT_ALGORITHM="HS256"
JWT_EXPIRE_HOURS=24

# --- Banco de Dados (OBRIGATÓRIO) ---
# Copie do painel PostgreSQL do Railway
DATABASE_URL=""

# --- Apify / Motor 2 (OBRIGATÓRIO) ---
# Obtenha em: https://console.apify.com/account/integrations
APIFY_TOKEN=""

# --- Mercado Pago (OBRIGATÓRIO) ---
# Obtenha em: https://www.mercadopago.com.br/developers/panel/app
MP_ACCESS_TOKEN=""
MP_PUBLIC_KEY=""
# URL pública do seu Back-end no Railway (ex: https://xxx.up.railway.app)
MP_WEBHOOK_URL=""
# Gerado ao configurar o Webhook no painel do MP (pode deixar vazio no início)
MP_WEBHOOK_SECRET=""

# --- Meta Graph API / Motor 1 (OPCIONAL na fase inicial) ---
META_APP_ID=""
META_APP_SECRET=""
